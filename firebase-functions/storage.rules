rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shir Glassworks build media — admin write, public read
    match /shirglassworks/builds/{buildId}/{mediaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
