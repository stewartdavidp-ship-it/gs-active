rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shir Glassworks build media — admin write, public read
    match /shirglassworks/builds/{buildId}/{mediaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Shir Glassworks training images — admin write, public read (for model training)
    match /shirglassworks/training-images/{productId}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Shir Glassworks image library — admin write, public read
    match /shirglassworks/images/{imageId}/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Shir Glassworks commission uploads — anonymous write (max 5MB images), admin read
    match /shirglassworks/commissions/{commissionId}/{file} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Shir Glassworks commission documents — admin write (max 10MB), public read
    match /shirglassworks/commission-docs/{commissionId}/{file} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
